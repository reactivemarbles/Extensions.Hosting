<Window
    x:Class="Extensions.Hosting.Avalonia.Example.MainWindow"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="Avalonia Demo"
    Width="800"
    Height="450">
    <StackPanel Margin="20" Spacing="10">
        <TextBlock FontSize="24" FontWeight="Bold">Welcome to Avalonia with Generic Host!</TextBlock>
        <TextBlock TextWrapping="Wrap">
            This is a sample Avalonia application using Extensions.Hosting.Avalonia.
        </TextBlock>
        <Button
            Name="ExitButton"
            HorizontalAlignment="Left"
            Content="Exit Application" />
    </StackPanel>
</Window>
