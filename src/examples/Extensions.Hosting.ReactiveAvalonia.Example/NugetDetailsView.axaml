<reactiveui:ReactiveUserControl
    x:Class="Extensions.Hosting.ReactiveAvalonia.Example.NugetDetailsView"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:Extensions.Hosting.ReactiveAvalonia.Example"
    xmlns:reactiveui="clr-namespace:ReactiveUI.Avalonia;assembly=ReactiveUI.Avalonia"
    x:TypeArguments="local:NugetDetailsViewModel"
    x:DataType="local:NugetDetailsViewModel">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <Image
            x:Name="IconImage"
            Width="64"
            Height="64"
            Margin="6"
            HorizontalAlignment="Center"
            Source="{Binding Icon}"
            VerticalAlignment="Center" />

        <StackPanel
            Grid.Column="1"
            Margin="6"
            VerticalAlignment="Center"
            Spacing="3">
            <TextBlock
                x:Name="TitleRun"
                FontSize="14"
                FontWeight="SemiBold"
                Text="{Binding Title}"
                TextWrapping="Wrap" />
            <TextBlock
                x:Name="DescriptionRun"
                FontSize="12"
                Text="{Binding Description}"
                TextWrapping="Wrap" />
            <Button
                x:Name="OpenButton"
                Command="{Binding OpenPage}"
                HorizontalAlignment="Left"
                Content="Open" />
        </StackPanel>
    </Grid>
</reactiveui:ReactiveUserControl>
